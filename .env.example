# Copy this file to .env.local and replace the example values.
# Supabase values are available from the project Connect panel.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Public URL used to build absolute links and metadata locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
